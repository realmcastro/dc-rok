# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://dcrok_app:dcrok_app_password@localhost:5432/dcrok?schema=public
# Migration role: must have DDL + UPDATE/DELETE on audit_logs (only used for migrations and admin operations).
DATABASE_MIGRATION_URL=postgresql://dcrok_owner:dcrok_owner_password@localhost:5432/dcrok?schema=public

# Discord
DISCORD_TOKEN=replace-me
DISCORD_APP_ID=replace-me
DISCORD_DEV_GUILD_ID=replace-me

# Admin allow-list (comma-separated Discord user IDs)
ADMIN_DISCORD_USER_IDS=

# Rate limit (requests per minute per user, applied to /init)
RATE_LIMIT_INIT_PER_MIN=5

# License key/code hashing pepper. Generate with: openssl rand -hex 32
LICENSE_HASH_PEPPER=replace-me-with-64-hex-chars-or-base64-of-32-bytes-of-entropy
